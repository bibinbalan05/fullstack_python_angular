# Ignore files for Docker build
.git
.gitignore
README.md
Dockerfile
.dockerignore
__pycache__
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-selfcheck.json
.env
.DS_Store
node_modules/
npm-debug.log*
.nyc_output
dist/
.cache/

# SSL Certificates and Keys - Keep out of Docker images!
ssl_certificates/
../ssl_certificates/
*.pem
*.key
*.crt
*.p12
*.pfx
server-ca.pem
client-cert.pem
client-key.pem
